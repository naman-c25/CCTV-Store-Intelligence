# Apex Store Intelligence — example environment configuration.
# Copy to `.env` and adjust. Nothing here is required: the app boots with these
# defaults (see app/config.py). docker-compose sets DATABASE_URL/POS_CSV itself.

# --- Storage -----------------------------------------------------------------
# Local default is SQLite (zero infra). docker-compose overrides with Postgres.
DATABASE_URL=sqlite:///./store_intel.db
# DATABASE_URL=postgresql+psycopg2://apex:apex@db:5432/store_intel

# Optional: auto-load POS transactions from a CSV on startup (path in container).
POS_CSV=/data/pos_transactions.csv

# --- Optional: VLM-assisted staff classification -----------------------------
# If set, pipeline/staff.py uses a vision LLM; otherwise it falls back to the
# colour-histogram heuristic.
ANTHROPIC_API_KEY=
VLM_MODEL=claude-haiku-4-5-20251001

# --- Business rules (North Star = offline conversion rate) --------------------
CONVERSION_WINDOW_MIN=5          # billing presence within N min before a POS txn = converted
DWELL_EMIT_SECONDS=30            # ZONE_DWELL re-emit cadence
MIN_SESSIONS_FOR_CONFIDENCE=20   # below this -> data_confidence flag on metrics/heatmap
MAX_INGEST_BATCH=500             # /events/ingest batch ceiling
BUSINESS_TZ_OFFSET_HOURS=5.5     # IST — defines "today"

# --- Operational / anomaly thresholds ----------------------------------------
STALE_FEED_MINUTES=10            # /health STALE_FEED warning lag
DEAD_ZONE_MINUTES=30             # no visits this long while store active -> DEAD_ZONE
QUEUE_SPIKE_DEPTH=5              # billing queue depth that trips BILLING_QUEUE_SPIKE
CONVERSION_DROP_PCT=0.30         # drop vs rolling baseline that trips CONVERSION_DROP
LOW_CONFIDENCE_THRESHOLD=0.40    # detections below this are flagged (never dropped)
